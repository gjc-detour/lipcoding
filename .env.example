# Azure OpenAI Configuration
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_WHISPER_DEPLOYMENT=whisper

# Storage backend: "sqlite" (default) or "cosmos"
STORAGE_BACKEND=sqlite

# Azure Cosmos DB (required when STORAGE_BACKEND=cosmos)
COSMOS_CONNECTION_STRING=AccountEndpoint=https://xxx.documents.azure.com:443/;AccountKey=xxx==;
# OR use managed identity:
COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/

# Azure Blob Storage (for uploaded files)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=xxx;AccountKey=xxx==;EndpointSuffix=core.windows.net

# Azure Document Intelligence (for PDF extraction)
# Create a resource at: https://portal.azure.com → Document Intelligence
# Leave blank to use unpdf fallback (no Azure resource needed)
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=your-key-here

# Server
PORT=3001
LOG_LEVEL=info

# Multi-user: comma-separated "userId:displayName:token"
# Leave empty for single-user mode (userId="default", no auth required)
ALLOWED_USERS=

# Azure Communication Services — for email notifications
# Create ACS resource: https://portal.azure.com → Communication Services
AZURE_COMMUNICATION_CONNECTION_STRING=endpoint=https://xxx.communication.azure.com/;accesskey=xxx
NOTIFICATION_FROM_EMAIL=notifications@yourdomain.azurecomm.net
NOTIFICATION_TO_EMAIL=your-email@example.com
